flowchart TD
    %% --- TOP-DOWN MAIN FLOW ---
    Start([Start System]) --> MainMenu{Main Menu}
    
    MainMenu -->|1. Register| Register[Register Customer Account]
    Register --> MainMenu
    
    MainMenu -->|2. Login| Login[Enter Username & Password]
    Login --> Auth{Credentials Valid?}
    Auth -->|No| Login
    
    MainMenu -->|Z. Exit| Exit([Shutdown & Save Data])

    Auth -->|Yes| CheckRole{User Role?}
    CheckRole -->|Customer| CustMenu
    CheckRole -->|Admin| AdminMenu

    %% --- CUSTOMER OPERATIONS SUBGRAPH ---
    subgraph CUSTOMER ["Customer Operations"]
        CustMenu{Customer Dashboard}
        
        CustMenu <--> Search[Search & Browse Vehicles]
        CustMenu <--> Rent[Rent Available Vehicle]
        CustMenu <--> Return[Return & Inspect Vehicle]
        CustMenu <--> Trip[Plan Trip & Suggest Vehicles]
        CustMenu <--> History[View Rental History]
        
        CustMenu -->|Z. Logout| CustLogout([Logout])
    end

    %% --- ADMIN OPERATIONS SUBGRAPH ---
    subgraph ADMIN ["Admin Operations"]
        AdminMenu{Admin Dashboard}
        
        AdminMenu <--> AddV[Add New Vehicle]
        AdminMenu --> RemV[Remove Vehicle]
        AdminMenu --> RemU[Remove User Profile]
        AdminMenu --> SP[Sell or Purchase Vehicles]
        AdminMenu --> View[View All Fleet & Users]
        AdminMenu --> Txns[View Transaction Logs]
        
        RemV --> AdminMenu
        RemU --> AdminMenu
        SP --> AdminMenu
        View --> AdminMenu
        Txns --> AdminMenu
        
        AdminMenu -->|Z. Logout| AdminLogout([Logout])
    end

    %% --- SIDE-BY-SIDE SPACING ---
    CUSTOMER ~~~ ADMIN

    %% --- LOGOUT ROUTING ---
    CustLogout --> MainMenu
    AdminLogout --> MainMenu
